{
  "ConnectionStrings": {
    "Chronoscope": "Host=localhost;Port=5432;Database=chronoscope;Username=postgres;Password=postgres"
  },
  "OneDrive": {
    "Auth": {
      "Instance": "https://login.microsoftonline.com/",
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "Scopes": [
        "User.Read",
        "Files.Read",
        "offline_access"
      ]
    }
  },
  "DataProtection": {
    "KeysPath": "/var/lib/chronoscope/data-protection-keys"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
