{
  "ConnectionStrings": {
    "Chronoscope": "Host=localhost;Port=5438;Database=chronoscope_dev;Username=postgres;Password=postgres"
  },
  "OneDrive": {
    "Auth": {
      "Instance": "https://login.microsoftonline.com/",
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "Scopes": [
        "User.Read",
        "Files.Read",
        "offline_access"
      ]
    }
  },
  "DataProtection": {
    "KeysPath": ".chronoscope-data-protection-keys"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Display.MessageTemplateTextFormatter, Serilog",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
